---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Nikita Gorokhov",
      url: "https://nikitacometa.dev/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Nikita Gorokhov",
      logo: {
        "@type": "ImageObject",
        url: "https://nikitacometa.dev/nikita-avatar.jpg",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://nikitacometa.dev/nikita-avatar.jpg",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Nikita Gorokhov",
    url: "https://nikitacometa.dev",
    image: "https://nikitacometa.dev/nikita-avatar.jpg",
    sameAs: [
      "https://github.com/nikitacometa",
      "https://twitter.com/NikitaCometa",
      "https://instagram.com/nikita.cometa",
      "https://t.me/cometablog",
    ],
    jobTitle: "Software Engineer",
    description:
      "Developer, meditator, standup comic. Building with AI from Koh Phangan.",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Nikita Cometa",
    url: "https://nikitacometa.dev",
    description:
      "Developer, meditator, standup comic. Building with AI from Koh Phangan. Tech, brain, and why neither works as advertised.",
    author: {
      "@type": "Person",
      name: "Nikita Gorokhov",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://nikitacometa.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
